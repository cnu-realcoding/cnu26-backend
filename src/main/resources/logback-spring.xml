    <appender name="FILE" class="TODO">
        <file>${LOG_DIR}/${LOG_FILE}.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ========== 롤링 파일 (Rolling File Appender) ========== -->
    <!-- 파일 크기 또는 날짜 기준으로 로그 파일을 분리 -->
    <appender name="ROLLING_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${LOG_FILE}-rolling.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
        </encoder>

        <!-- 롤링 정책: 날짜 + 파일 크기 기반 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- TODO: 파일명 패턴을 작성하세요 (날짜별 + 인덱스) -->
            <!-- 힌트: ${LOG_DIR}/archived/${LOG_FILE}.%d{yyyy-MM-dd}.%i.log -->
            <fileNamePattern><!-- TODO --></fileNamePattern>
            <!-- TODO: 단일 파일 최대 크기를 설정하세요 (예: 10MB) -->
